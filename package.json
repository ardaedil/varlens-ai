{
  "name": "varlens-ai",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "contract:check": "node scripts/check-contracts.mjs",
    "dev:web": "pnpm --filter @varlens/web dev",
    "build:web": "pnpm --filter @varlens/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test:web": "pnpm --filter @varlens/web test",
    "dev:api": "python -m uvicorn services.api.app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "python -m pytest services/api/tests"
  }
}
