{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://varlens.local/schemas/analyze.schema.json",
  "title": "VARLens Analyze Contract",
  "oneOf": [
    { "$ref": "#/$defs/analyzeResponse" },
    { "$ref": "#/$defs/errorResponse" }
  ],
  "$defs": {
    "sanctionLabel": {
      "type": "string",
      "enum": ["no_offence", "offence_no_card", "offence_yellow", "offence_red"]
    },
    "actionTypeLabel": {
      "type": "string",
      "enum": [
        "standing_tackle",
        "tackle",
        "holding",
        "pushing",
        "challenge",
        "dive",
        "high_leg",
        "elbowing",
        "unknown"
      ]
    },
    "varReviewCategory": {
      "type": "string",
      "enum": ["not_applicable", "direct_red_related", "unsupported_in_v1"]
    },
    "reviewContextValue": {
      "type": "string",
      "enum": ["foul_review_context", "unsupported_scope"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sanctionAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence"],
      "properties": {
        "label": { "$ref": "#/$defs/sanctionLabel" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "actionAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence"],
      "properties": {
        "label": { "$ref": "#/$defs/actionTypeLabel" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "sanctionPrediction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence", "alternatives"],
      "properties": {
        "label": { "$ref": "#/$defs/sanctionLabel" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "alternatives": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/sanctionAlternative" }
        }
      }
    },
    "actionTypePrediction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence", "alternatives"],
      "properties": {
        "label": { "$ref": "#/$defs/actionTypeLabel" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "alternatives": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/actionAlternative" }
        }
      }
    },
    "reviewContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["var_review_category", "official_decision_claimed"],
      "properties": {
        "var_review_category": { "$ref": "#/$defs/varReviewCategory" },
        "official_decision_claimed": { "const": false }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_family", "rules_source", "frames_sampled"],
      "properties": {
        "dataset_family": { "type": "string", "minLength": 1 },
        "rules_source": { "type": "string", "minLength": 1 },
        "frames_sampled": { "type": "integer", "minimum": 0 }
      }
    },
    "analyzeResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec_version",
        "model_version",
        "request_id",
        "status",
        "sanction_prediction",
        "action_type_prediction",
        "viewer_focus",
        "explanation",
        "limitations",
        "review_context",
        "provenance"
      ],
      "properties": {
        "spec_version": { "const": "1.0.0" },
        "model_version": { "type": "string", "minLength": 1 },
        "request_id": {
          "type": "string",
          "format": "uuid"
        },
        "status": { "const": "ok" },
        "sanction_prediction": { "$ref": "#/$defs/sanctionPrediction" },
        "action_type_prediction": { "$ref": "#/$defs/actionTypePrediction" },
        "viewer_focus": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1 }
        },
        "explanation": { "type": "string", "minLength": 1 },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1 }
        },
        "review_context": { "$ref": "#/$defs/reviewContext" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "errorCode": {
      "type": "string",
      "enum": [
        "invalid_request",
        "clip_too_large",
        "unsupported_media_type",
        "clip_too_long",
        "unsupported_scope",
        "rate_limited",
        "inference_failed",
        "model_unavailable"
      ]
    },
    "errorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spec_version", "request_id", "status", "error"],
      "properties": {
        "spec_version": { "const": "1.0.0" },
        "request_id": { "type": "string", "format": "uuid" },
        "status": { "const": "error" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "$ref": "#/$defs/errorCode" },
            "message": { "type": "string", "minLength": 1 },
            "details": {
              "type": "object",
              "additionalProperties": {
                "type": ["string", "number", "boolean", "null"]
              }
            }
          }
        }
      }
    }
  }
}
